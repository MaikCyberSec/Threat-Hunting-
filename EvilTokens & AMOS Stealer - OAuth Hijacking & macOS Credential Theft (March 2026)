// ============================================================
// EvilTokens & AMOS Stealer — Advanced Hunting Detections
// OAuth Device Code Hijacking & macOS Credential Theft
// Source: ANY.RUN, Objective-See, CyberSecurityNews (March 2026)
// Platform: Microsoft Defender for Endpoint + Entra ID
// Author: Wortell MxDR SOC (@mlohn1984)
// ============================================================
//
// BACKGROUND:
// Two linked March 2026 campaigns:
//
// 1) EvilTokens — abuses Microsoft OAuth 2.0 Device Code flow to
//    silently hijack enterprise accounts. Over 180 phishing URLs
//    detected in a single week. Targets: Tech, Education,
//    Manufacturing, Government (US & India focus).
//
// 2) AMOS (Atomic macOS Stealer) — distributed via ClickFix campaign
//    using trojanized DMG (Clearl_AI.dmg). Harvests browser passwords,
//    macOS Keychain, crypto wallets (256 extensions), Apple Notes.
//    Deploys persistent backdoor (~/.mainhelper) with WebSocket
//    reverse shell. Kills security tools (Little Snitch, BlockBlock,
//    Lulu). Specifically targets AI developers and Claude Code users.
//
// MITRE ATT&CK:
//   T1528       - Steal Application Access Token
//   T1566.002   - Phishing: Spearphishing Link
//   T1550.001   - Use Alternate Authentication Material: App Access Token
//   T1204.002   - User Execution: Malicious File
//   T1059.004   - Command and Scripting Interpreter: Unix Shell
//   T1547.011   - Boot/Logon Autostart: Plist Modification
//   T1555.001   - Credentials from Password Stores: Keychain
//   T1555.003   - Credentials from Password Stores: Web Browsers
//   T1560.001   - Archive Collected Data: Archive via Utility
//   T1071.001   - Application Layer Protocol: Web Protocols (WebSocket C2)
//   T1562.001   - Impair Defenses: Disable or Modify Tools
//   T1497.001   - Virtualization/Sandbox Evasion: System Checks
//   T1036.005   - Masquerading: Match Legitimate Name
//
// IOCs:
//   Domains:
//     singer-bodners-bau-at-s-account[.]workers[.]dev (EvilTokens phishing)
//     dibafef289[.]workers[.]dev (EvilTokens phishing)
//     laislivon[.]com (AMOS C2/exfil)
//     rvdownloads[.]com (AMOS payload delivery)
//     mac-force.squarespace[.]com (AMOS lure page)
//   URLs:
//     rvdownloads[.]com/frozenfix/update (AMOS helper payload)
//   SHA256:
//     57ce6187be65c1c692a309c08457290ae74a0047304de6805dbb4feb89c0d7e5
//     6a581c3b6fe7847bb327f5d76e05653a1504e51023454c41835e5dc48bc13ba4
//   Files:
//     Clearl_AI.dmg (delivery), ~/.mainhelper (backdoor),
//     /tmp/helper (payload), /tmp/archive.tar.gz (exfil),
//     ~/.pwd, ~/.marker, ~/.username (staging artifacts)
//   Plists:
//     com.apple.mdworker.plist, com.apple.systemupdate (persistence)
//   HTTP:
//     /api/device/start, X-Antibot-Token header (EvilTokens infra)
//
// REFERENCES:
//   https://cybersecuritynews.com/eviltokens-amos-march-2026-threat-campaigns/
//   https://objective-see.org/blog/blog_0x88.html
//   https://www.hendryadrian.com/major-cyber-attacks-in-march-2026-oauth-phishing-svg-smuggling-magecart-and-more/
//   https://www.darktrace.com/blog/atomic-stealer-darktraces-investigation-of-a-growing-macos-threat
//
// NOTE: Queries run against onboarded Defender for Endpoint devices
// only. Unmanaged macOS/BYOD devices will NOT appear in results.
// The Entra ID query (Query 1) covers all sign-ins regardless of
// device onboarding status.
// ============================================================


// ============================================================
// EVILTOKENS CAMPAIGN
// ============================================================


// ------------------------------------------------------------
// 1. OAUTH DEVICE CODE SIGN-IN ANOMALIES
//    Detects successful sign-ins using the Device Code protocol
//    which is the core mechanism abused by EvilTokens.
//    Device Code flow is designed for input-limited devices
//    (smart TVs, IoT) — usage from regular workstations is
//    suspicious.
// ------------------------------------------------------------
AADSignInEventsBeta
| where Timestamp > ago(30d)
| where AuthenticationProtocol == "deviceCode"
| where ErrorCode == 0
| project Timestamp, AccountUpn, AccountObjectId, ApplicationId,
    IPAddress, Country, DeviceName, SessionId, RiskLevelDuringSignIn
| sort by Timestamp desc


// ------------------------------------------------------------
// 2. EVILTOKENS PHISHING DOMAIN CONNECTIONS
//    Detects connections to known EvilTokens workers.dev
//    phishing infrastructure and suspicious OAuth-related
//    patterns on workers.dev domains.
// ------------------------------------------------------------
DeviceNetworkEvents
| where Timestamp > ago(30d)
| where RemoteUrl has_any (
    "singer-bodners-bau-at-s-account.workers.dev",
    "dibafef289.workers.dev")
    or (RemoteUrl has "workers.dev"
        and RemoteUrl has_any ("device", "oauth", "token", "antibot"))
| project Timestamp, DeviceName, RemoteUrl, RemoteIP, RemotePort,
    InitiatingProcessFileName, InitiatingProcessCommandLine, ActionType
| sort by Timestamp desc


// ------------------------------------------------------------
// 3. MASS DEVICE CODE REQUESTS (SPRAY DETECTION)
//    Detects multiple device code authentications from the same
//    IP or for the same application — indicator of automated
//    phishing campaign.
// ------------------------------------------------------------
AADSignInEventsBeta
| where Timestamp > ago(7d)
| where AuthenticationProtocol == "deviceCode"
| summarize
    AttemptCount = count(),
    UniqueAccounts = dcount(AccountUpn),
    Accounts = make_set(AccountUpn, 25),
    Applications = make_set(ApplicationId, 10)
    by IPAddress, Country
| where AttemptCount > 3 or UniqueAccounts > 1
| sort by AttemptCount desc


// ============================================================
// AMOS STEALER CAMPAIGN
// ============================================================


// ------------------------------------------------------------
// 4. AMOS C2 AND PAYLOAD DOMAIN CONNECTIONS
//    Detects network connections to known AMOS infrastructure:
//    - laislivon.com (C2 / data exfiltration)
//    - rvdownloads.com (payload delivery)
//    - mac-force.squarespace.com (initial lure)
// ------------------------------------------------------------
DeviceNetworkEvents
| where Timestamp > ago(30d)
| where RemoteUrl has_any (
    "laislivon.com",
    "rvdownloads.com",
    "mac-force.squarespace.com")
    or RemoteUrl has "frozenfix/update"
| project Timestamp, DeviceName, RemoteUrl, RemoteIP, RemotePort,
    InitiatingProcessFileName, InitiatingProcessCommandLine
| sort by Timestamp desc


// ------------------------------------------------------------
// 5. AMOS FILE HASH IOC MATCHING
//    Matches known AMOS malware hashes across file events
// ------------------------------------------------------------
DeviceFileEvents
| where Timestamp > ago(30d)
| where SHA256 in (
    "57ce6187be65c1c692a309c08457290ae74a0047304de6805dbb4feb89c0d7e5",
    "6a581c3b6fe7847bb327f5d76e05653a1504e51023454c41835e5dc48bc13ba4")
| project Timestamp, DeviceName, FileName, FolderPath, SHA256,
    InitiatingProcessFileName, ActionType


// ------------------------------------------------------------
// 6. CLICKFIX EXECUTION — BASE64 CURL PIPED TO SHELL
//    Detects the AMOS initial access vector: a base64-encoded
//    curl command piped to zsh/bash, triggered from a lure page.
//    Also detects the Clearl_AI.dmg delivery file.
// ------------------------------------------------------------
DeviceProcessEvents
| where Timestamp > ago(30d)
| where
    // ClickFix pattern: curl with base64 piped to shell
    (ProcessCommandLine has "curl"
     and ProcessCommandLine has_any ("base64", "| zsh", "| bash", "| sh"))
    // Trojanized DMG file
    or ProcessCommandLine has "Clearl_AI"
| project Timestamp, DeviceName, FileName, ProcessCommandLine,
    InitiatingProcessFileName, InitiatingProcessCommandLine,
    AccountName, FolderPath
| sort by Timestamp desc


// ------------------------------------------------------------
// 7. AMOS PERSISTENCE — LAUNCHAGENT & BACKDOOR
//    Detects AMOS persistence mechanisms:
//    - com.apple.mdworker.plist (masquerades as Spotlight)
//    - com.apple.systemupdate (masquerades as macOS update)
//    - ~/.mainhelper (WebSocket reverse shell backdoor)
// ------------------------------------------------------------
DeviceProcessEvents
| where Timestamp > ago(30d)
| where ProcessCommandLine has_any (
    ".mainhelper",
    "com.apple.mdworker",
    "com.apple.systemupdate",
    "/tmp/helper")
| project Timestamp, DeviceName, FileName, ProcessCommandLine,
    InitiatingProcessFileName, AccountName, FolderPath
| sort by Timestamp desc


// ------------------------------------------------------------
// 8. AMOS — SECURITY TOOL KILLING
//    Detects AMOS attempting to kill macOS security tools:
//    Little Snitch, BlockBlock, and Lulu (Objective-See tools)
// ------------------------------------------------------------
DeviceProcessEvents
| where Timestamp > ago(30d)
| where FileName in ("kill", "killall", "pkill")
| where ProcessCommandLine has_any (
    "Little Snitch", "LittleSnitch",
    "BlockBlock", "blockblock",
    "Lulu", "LuLu", "lulu")
| project Timestamp, DeviceName, FileName, ProcessCommandLine,
    InitiatingProcessFileName, AccountName
| sort by Timestamp desc


// ------------------------------------------------------------
// 9. AMOS — KEYCHAIN CREDENTIAL HARVESTING
//    Detects macOS Keychain password extraction using the
//    security command-line tool. AMOS uses:
//    security find-generic-password -wa <service>
// ------------------------------------------------------------
DeviceProcessEvents
| where Timestamp > ago(30d)
| where FileName == "security"
| where ProcessCommandLine has "find-generic-password"
| project Timestamp, DeviceName, FileName, ProcessCommandLine,
    InitiatingProcessFileName, InitiatingProcessCommandLine,
    AccountName
| sort by Timestamp desc


// ------------------------------------------------------------
// 10. AMOS — SUSPICIOUS FILE ARTIFACTS
//     Detects AMOS staging files on disk:
//     - /tmp/helper (executable payload)
//     - /tmp/archive.tar.gz (exfiltration archive)
//     - ~/.mainhelper (backdoor binary)
//     - ~/.pwd, ~/.marker, ~/.username (infection markers)
// ------------------------------------------------------------
DeviceFileEvents
| where Timestamp > ago(30d)
| where FileName in ("helper", "archive.tar.gz", ".mainhelper",
        ".pwd", ".marker", ".username")
    or FolderPath has_any ("/tmp/helper", "/tmp/update_",
        "/tmp/archive.tar.gz")
    or (FolderPath has "LaunchAgents"
        and FileName has_any ("com.apple.mdworker",
            "com.apple.systemupdate"))
| project Timestamp, DeviceName, FileName, FolderPath,
    ActionType, InitiatingProcessFileName, SHA256
| sort by Timestamp desc


// ------------------------------------------------------------
// 11. AMOS — DATA EXFILTRATION STAGING
//     Detects tar archive creation in /tmp (AMOS compresses
//     stolen data before exfiltration to laislivon.com)
// ------------------------------------------------------------
DeviceProcessEvents
| where Timestamp > ago(30d)
| where FileName == "tar"
| where ProcessCommandLine has_any ("/tmp/archive", "/tmp/update_")
| project Timestamp, DeviceName, FileName, ProcessCommandLine,
    InitiatingProcessFileName, AccountName
| sort by Timestamp desc


// ------------------------------------------------------------
// 12. COMPREHENSIVE MULTI-SIGNAL CORRELATION (HIGH FIDELITY)
//     Links AMOS attack stages: ClickFix execution ->
//     persistence creation -> C2 communication
//     Use for high-confidence incident investigation
// ------------------------------------------------------------
let ClickFixExec = DeviceProcessEvents
| where Timestamp > ago(30d)
| where ProcessCommandLine has "curl"
    and ProcessCommandLine has_any ("base64", "| zsh", "| bash")
| project DeviceName, AccountSid, ExecTime = Timestamp,
    ExecCmd = ProcessCommandLine;

let PersistEvents = DeviceProcessEvents
| where Timestamp > ago(30d)
| where ProcessCommandLine has_any (
    ".mainhelper", "com.apple.mdworker",
    "com.apple.systemupdate", "/tmp/helper")
| project DeviceName, AccountSid, PersistTime = Timestamp,
    PersistCmd = ProcessCommandLine;

let C2Comms = DeviceNetworkEvents
| where Timestamp > ago(30d)
| where RemoteUrl has_any ("laislivon.com", "rvdownloads.com")
| project DeviceName, C2Time = Timestamp,
    RemoteUrl, RemoteIP;

ClickFixExec
| join kind=inner PersistEvents on DeviceName, AccountSid
| join kind=inner C2Comms on DeviceName
| where PersistTime > ExecTime
| where C2Time > ExecTime
| project ExecTime, PersistTime, C2Time, DeviceName,
    ExecCmd, PersistCmd, RemoteUrl, RemoteIP
| sort by ExecTime desc
