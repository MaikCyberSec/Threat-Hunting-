// ============================================================
// Pwn2Own Berlin 2026 — Day 1 Exposure & Hunting Pack
// Edge sandbox escape · Windows 11 LPE · LiteLLM RCE
// NVIDIA Megatron Bridge / Container Toolkit · OpenAI Codex
// Source:   CyberSecurity News / Zero Day Initiative (May 15 2026)
// Platform: Microsoft Defender for Endpoint (Advanced Hunting)
// MITRE ATT&CK: T1190, T1611, T1068, T1212, T1059.006,
//               T1611, T1574.002, T1218.011
// ============================================================
//
// THREAT SUMMARY
// ---------------------------------------------------------------
// Pwn2Own Berlin 2026 Day 1 paid out $523,000 across 24 unique
// zero-day vulnerabilities. Every demonstrated bug is currently
// pre-patch and pre-CVE — ZDI gives vendors 90 days to ship a
// fix. There are therefore NO IOCs, NO hashes and NO patched-
// version numbers to hunt against yet.
//
// What this pack delivers is POSTURE and BEHAVIOURAL HUNTING
// against the technique class of each demonstrated bug:
//
//   - Microsoft Edge sandbox escape (Orange Tsai / DEVCORE,
//     $175,000, 4 chained logic flaws). Hunt: anomalous Edge
//     child processes, integrity uplift from Edge renderer.
//   - Windows 11 privilege escalations (DEVCORE, Angelboy &
//     TwinkleStar03; heap buffer overflow, UAF, improper
//     access control). Hunt: kernel-LPE exploit primitives,
//     unexpected SYSTEM children, exploit-style cmdline
//     fingerprints.
//   - LiteLLM full-chain RCE (k3vg3n, $40,000; SSRF +
//     code injection, 3 vulns). Hunt: LiteLLM inventory,
//     SSRF probe patterns, cloud-metadata access, RCE-style
//     spawning from python LiteLLM workers.
//   - OpenAI Codex (Compass Security, CWE-150 flaw). Hunt:
//     Codex CLI / endpoint inventory across developer fleet.
//   - NVIDIA Megatron Bridge path traversal / allow-list
//     bypass. Hunt: Megatron / NeMo inventory + anomalous
//     file access on AI training boxes.
//   - NVIDIA Container Toolkit container escape (IBM X-Force).
//     Hunt: nvidia-container-cli / containerd / runc with
//     unusual flags and parent context.
//
// Vendor patches expected within the 90-day ZDI disclosure
// window. Treat this pack as your "exposure heatmap" until
// then — and as your "ready to hunt" content when patches
// drop.
//
// CONTEST QUOTE
// ---------------------------------------------------------------
// "Attackers are no longer focused solely on traditional
//  software but are actively targeting AI platforms, inference
//  engines, and developer tools."
//
// LICENSING / TABLE NOTES
// ---------------------------------------------------------------
//   DeviceTvmSoftwareInventory / Vulnerabilities — surfaces
//   Edge / Windows 11 / LiteLLM / NVIDIA software once
//   Microsoft ingests the CVE feed.
//   Other tables are standard MDE Advanced Hunting.
//
// REFERENCES
// ---------------------------------------------------------------
//   https://cybersecuritynews.com/pwn2own-berlin-2026/
// ============================================================


// ------------------------------------------------------------
// 1. INVENTORY — PWN2OWN BERLIN 2026 PRODUCT EXPOSURE
//    Single posture pull for the entire fleet's exposure to
//    each demonstrated bug class. Run this first; it answers
//    "how big is my blast radius?" before you hunt activity.
// ------------------------------------------------------------
DeviceTvmSoftwareInventory
| where SoftwareName has_any (
    "Edge", "Microsoft Edge",
    "Windows 11", "Windows",
    "LiteLLM", "litellm",
    "OpenAI Codex", "Codex",
    "NVIDIA Container Toolkit", "nvidia-container-toolkit",
    "NVIDIA Megatron", "Megatron", "NeMo",
    "Docker Desktop", "VMware Workstation"
)
   or SoftwareVendor has_any ("Microsoft", "NVIDIA", "BerriAI", "OpenAI")
| project DeviceId, DeviceName, OSPlatform, OSVersion,
          SoftwareVendor, SoftwareName, SoftwareVersion
| order by SoftwareName asc, DeviceName asc


// ------------------------------------------------------------
// 2. EDGE SANDBOX ESCAPE — RENDERER / SANDBOX CHILD ANOMALY
//    Edge runs renderers / utility processes as low-integrity
//    children of msedge.exe. A renderer that spawns cmd /
//    powershell / mshta / rundll32 / regsvr32 is essentially
//    diagnostic of an escape (Orange Tsai / DEVCORE class).
// ------------------------------------------------------------
DeviceProcessEvents
| where Timestamp > ago(14d)
| where InitiatingProcessFileName =~ "msedge.exe"
| where InitiatingProcessCommandLine has_any (
    "--type=renderer", "--type=utility",
    "--type=gpu-process", "--type=zygote"
)
| where FileName in~ (
    "cmd.exe", "powershell.exe", "pwsh.exe",
    "mshta.exe", "rundll32.exe", "regsvr32.exe",
    "wscript.exe", "cscript.exe",
    "bitsadmin.exe", "certutil.exe", "wmic.exe"
)
| project Timestamp, DeviceName, AccountName,
          InitiatingProcessFileName, InitiatingProcessCommandLine,
          InitiatingProcessIntegrityLevel,
          FileName, FolderPath, ProcessCommandLine,
          ProcessIntegrityLevel
| order by Timestamp desc


// ------------------------------------------------------------
// 3. EDGE INTEGRITY UPLIFT — RENDERER → HIGH / SYSTEM
//    The sandbox-escape moment. Edge renderer runs at Low /
//    Untrusted integrity. A child running at High or System
//    is the exploit succeeding.
// ------------------------------------------------------------
DeviceProcessEvents
| where Timestamp > ago(14d)
| where InitiatingProcessFileName =~ "msedge.exe"
| where InitiatingProcessIntegrityLevel in~ ("Low", "Untrusted", "AppContainer")
| where ProcessIntegrityLevel in~ ("High", "System")
| where FileName !in~ ("WerFault.exe", "WerFaultSecure.exe", "conhost.exe")
| project Timestamp, DeviceName, AccountName,
          InitiatingProcessFileName, InitiatingProcessIntegrityLevel,
          FileName, FolderPath, ProcessCommandLine,
          ProcessIntegrityLevel
| order by Timestamp desc


// ------------------------------------------------------------
// 4. WINDOWS 11 LPE EXPLOIT-PRIMITIVE PATTERNS
//    Generic hunt for the Win11 kernel-LPE class demonstrated
//    by DEVCORE / Angelboy / TwinkleStar03 — heap UAF, IAC
//    issues. Look for PowerShell / .NET cmdlines invoking the
//    Win32 / NT primitives commonly used.
// ------------------------------------------------------------
DeviceProcessEvents
| where Timestamp > ago(14d)
| where FileName in~ ("powershell.exe", "pwsh.exe", "cmd.exe",
                       "rundll32.exe", "regsvr32.exe",
                       "InstallUtil.exe", "RegAsm.exe", "RegSvcs.exe",
                       "MSBuild.exe", "csc.exe")
| where ProcessCommandLine has_any (
    "NtQuerySystemInformation", "NtSetInformationProcess",
    "NtMapViewOfSection", "NtCreateSection",
    "NtUserConsoleControl", "NtUserMessageCall",
    "win32k.sys", "win32kfull",
    "MmGetPhysicalAddress", "PsLookupProcessByProcessId",
    "ObReferenceObjectByHandle"
)
| where ProcessCommandLine has_any (
    "VirtualAlloc", "VirtualProtect",
    "AllocateVirtualMemory", "MapViewOfSection"
)
| project Timestamp, DeviceName, AccountName,
          FileName, FolderPath, ProcessCommandLine,
          InitiatingProcessFileName, InitiatingProcessCommandLine,
          InitiatingProcessIntegrityLevel, ProcessIntegrityLevel
| order by Timestamp desc


// ------------------------------------------------------------
// 5. UNEXPECTED MEDIUM-INTEGRITY → SYSTEM CHILD
//    The exploitable outcome of any Win11 LPE chain — a normal
//    user-context process producing a System child without
//    going through UAC / a trusted installer.
// ------------------------------------------------------------
DeviceProcessEvents
| where Timestamp > ago(14d)
| where InitiatingProcessIntegrityLevel in~ ("Medium", "Low")
| where ProcessIntegrityLevel =~ "System"
| where InitiatingProcessFileName !in~ (
    "consent.exe", "RuntimeBroker.exe",
    "msiexec.exe", "TiWorker.exe",
    "trustedinstaller.exe", "wuauclt.exe",
    "WindowsUpdateBox.exe", "OneDriveSetup.exe",
    "WerFault.exe", "WerFaultSecure.exe"
)
| where FileName !in~ (
    "consent.exe", "WerFault.exe", "WerFaultSecure.exe",
    "conhost.exe", "splwow64.exe"
)
| project Timestamp, DeviceName, AccountName,
          InitiatingProcessFileName, InitiatingProcessFolderPath,
          InitiatingProcessIntegrityLevel,
          FileName, FolderPath, ProcessCommandLine,
          ProcessIntegrityLevel
| order by Timestamp desc


// ------------------------------------------------------------
// 6. LITELLM PROXY INVENTORY + EXPOSURE
//    Python processes running LiteLLM as a proxy / gateway.
//    Catches both standalone deployments and containers
//    onboarded to MDE for Linux.
// ------------------------------------------------------------
DeviceProcessEvents
| where Timestamp > ago(14d)
| where (FileName in~ ("python", "python3", "python.exe", "pythonw.exe")
         and ProcessCommandLine has_any ("litellm", "litellm.proxy", "litellm[proxy]"))
   or FileName =~ "litellm"
   or ProcessCommandLine has "--config litellm"
| project Timestamp, DeviceName, AccountName,
          FileName, FolderPath, ProcessCommandLine,
          InitiatingProcessFileName, InitiatingProcessCommandLine
| order by Timestamp desc


// ------------------------------------------------------------
// 7. LITELLM SSRF / CLOUD-METADATA PROBE PATTERNS
//    The k3vg3n full-chain RCE started with SSRF. Surface
//    LiteLLM Python workers (or any Python parented by a
//    LiteLLM proxy) reaching IMDS / link-local / loopback
//    metadata endpoints.
// ------------------------------------------------------------
DeviceNetworkEvents
| where Timestamp > ago(14d)
| where ActionType == "ConnectionSuccess"
| where RemoteIP in ("169.254.169.254", "100.100.100.200",
                      "169.254.169.123", "127.0.0.1", "::1")
   or RemoteUrl has_any (
        "metadata.google.internal",
        "metadata.azure.com",
        "169.254.169.254",
        "ec2.internal"
   )
| where InitiatingProcessFileName in~ (
    "python", "python3", "python.exe", "pythonw.exe", "litellm"
)
| where InitiatingProcessCommandLine has_any ("litellm", "uvicorn", "gunicorn")
   or InitiatingProcessFolderPath has @"site-packages/litellm"
| project Timestamp, DeviceName,
          InitiatingProcessFileName, InitiatingProcessCommandLine,
          RemoteIP, RemotePort, RemoteUrl
| order by Timestamp desc


// ------------------------------------------------------------
// 8. CODE-EXECUTION FROM A LITELLM PYTHON WORKER
//    The chain ends in RCE. A LiteLLM-parented worker
//    spawning sh / bash / cmd / powershell with arbitrary
//    commands is the exploitation success signal.
// ------------------------------------------------------------
DeviceProcessEvents
| where Timestamp > ago(14d)
| where InitiatingProcessFileName in~ ("python", "python3", "python.exe", "pythonw.exe")
| where InitiatingProcessCommandLine has_any ("litellm", "uvicorn", "gunicorn")
   or InitiatingProcessFolderPath has @"site-packages/litellm"
| where FileName in~ (
    "sh", "bash", "dash", "zsh",
    "cmd.exe", "powershell.exe", "pwsh.exe",
    "curl", "wget", "python", "python3"
)
| project Timestamp, DeviceName, AccountName,
          InitiatingProcessFileName, InitiatingProcessFolderPath,
          InitiatingProcessCommandLine,
          FileName, FolderPath, ProcessCommandLine
| order by Timestamp desc


// ------------------------------------------------------------
// 9. NVIDIA CONTAINER TOOLKIT — ESCAPE-CLASS PRIMITIVES
//    nvidia-container-cli / runc / containerd invoked with
//    arguments that touch host paths from inside a container
//    are an escape signature (IBM X-Force class).
// ------------------------------------------------------------
DeviceProcessEvents
| where Timestamp > ago(14d)
| where FileName in~ (
    "nvidia-container-cli", "nvidia-container-runtime",
    "nvidia-container-runtime-hook",
    "runc", "containerd", "containerd-shim",
    "containerd-shim-runc-v2"
)
| where ProcessCommandLine has_any (
    "/proc/self/root", "/var/run/docker.sock",
    "/var/lib/docker", "/host/", "..\\..",
    "/proc/1/root", "--no-pivot", "exec --privileged",
    "--security-opt label=disable",
    "--volume /:", "-v /:/"
)
| project Timestamp, DeviceName, AccountName,
          FileName, FolderPath, ProcessCommandLine,
          InitiatingProcessFileName, InitiatingProcessCommandLine
| order by Timestamp desc


// ------------------------------------------------------------
// 10. NVIDIA MEGATRON / NEMO BRIDGE — PATH TRAVERSAL TELL
//     Megatron Bridge had a path-traversal / allow-list
//     bypass. Surfaces Megatron / NeMo Python processes
//     touching files OUTSIDE the model / data directories.
// ------------------------------------------------------------
DeviceFileEvents
| where Timestamp > ago(14d)
| where InitiatingProcessCommandLine has_any (
    "megatron", "nemo", "megatron-bridge", "nemo-bridge",
    "Megatron-LM", "NVIDIA/Megatron"
)
| where FolderPath has_any (
    @"/etc/", @"/root/", @"/home/",
    @"/.ssh", @"/.aws", @"/.kube",
    @"\Windows\System32", @"\Users\Administrator"
)
   or FileName in~ ("passwd", "shadow", "authorized_keys", "id_rsa")
| project Timestamp, DeviceName,
          ActionType, FileName, FolderPath,
          InitiatingProcessFileName, InitiatingProcessCommandLine
| order by Timestamp desc


// ------------------------------------------------------------
// 11. OPENAI CODEX CLI / SDK USAGE POSTURE
//     Compass Security demonstrated a CWE-150 flaw in Codex.
//     This is a posture inventory — surface every workstation
//     using Codex CLI / GitHub Copilot CLI / SDK that calls
//     the Codex endpoint. No abuse alert; just visibility.
// ------------------------------------------------------------
union isfuzzy=true
(
    DeviceProcessEvents
    | where Timestamp > ago(30d)
    | where FileName in~ ("codex", "codex.exe", "openai", "openai.exe")
       or ProcessCommandLine has_any (
            "openai codex", "gh copilot",
            "openai api", "github.com/openai/codex-cli"
       )
    | extend EventKind = "ProcessExec"
    | project Timestamp, DeviceName, EventKind, AccountName,
              FileName, FolderPath, ProcessCommandLine,
              InitiatingProcessFileName, InitiatingProcessCommandLine,
              RemoteUrl = ""
),
(
    DeviceNetworkEvents
    | where Timestamp > ago(30d)
    | where ActionType == "ConnectionSuccess"
    | where RemoteUrl has_any (
        "api.openai.com/v1/engines/codex",
        "api.openai.com/v1/completions",
        "codex.openai.com"
    )
    | extend EventKind = "Network"
    | project Timestamp, DeviceName, EventKind, AccountName = "",
              FileName = "", FolderPath = "", ProcessCommandLine = "",
              InitiatingProcessFileName, InitiatingProcessCommandLine,
              RemoteUrl
)
| order by Timestamp desc


// ------------------------------------------------------------
// 12. POSTURE CORRELATION (FLEET-WIDE EXPOSURE SCORE)
//     Combines: vulnerable Edge versions, LiteLLM presence,
//     NVIDIA Container Toolkit presence, recent suspicious
//     activity. Produces a per-device exposure score useful
//     for CISO reporting until vendor patches ship.
// ------------------------------------------------------------
let EdgeFleet = DeviceTvmSoftwareInventory
| where SoftwareName has "Edge" and SoftwareVendor =~ "Microsoft"
| summarize by DeviceName;
let LiteLLMFleet = DeviceProcessEvents
| where Timestamp > ago(7d)
| where ProcessCommandLine has "litellm"
| summarize by DeviceName;
let NvCtkFleet = DeviceProcessEvents
| where Timestamp > ago(7d)
| where FileName in~ ("nvidia-container-cli", "nvidia-container-runtime",
                       "nvidia-container-runtime-hook")
| summarize by DeviceName;
let RecentSuspicious = DeviceProcessEvents
| where Timestamp > ago(7d)
| where (InitiatingProcessIntegrityLevel in~ ("Medium", "Low")
         and ProcessIntegrityLevel =~ "System"
         and InitiatingProcessFileName !in~ (
             "consent.exe", "msiexec.exe", "trustedinstaller.exe",
             "TiWorker.exe", "RuntimeBroker.exe"
         ))
| summarize SuspiciousElev = count() by DeviceName;
EdgeFleet
| extend HasEdge = 1
| join kind=fullouter (LiteLLMFleet | extend HasLiteLLM = 1) on DeviceName
| join kind=fullouter (NvCtkFleet | extend HasNvCtk = 1) on DeviceName
| join kind=fullouter RecentSuspicious on DeviceName
| extend Dev          = coalesce(DeviceName, DeviceName1, DeviceName2, DeviceName3)
| extend HasEdge      = coalesce(HasEdge,      0),
         HasLiteLLM   = coalesce(HasLiteLLM,   0),
         HasNvCtk     = coalesce(HasNvCtk,     0),
         SuspiciousElev = coalesce(SuspiciousElev, 0)
| extend ExposureScore =
       iff(HasEdge      == 1, 1, 0)
     + iff(HasLiteLLM   == 1, 3, 0)
     + iff(HasNvCtk     == 1, 3, 0)
     + iff(SuspiciousElev >= 1, 4, 0)
| where ExposureScore >= 3
| project DeviceName = Dev,
          HasEdge, HasLiteLLM, HasNvCtk,
          SuspiciousElev, ExposureScore
| order by ExposureScore desc
